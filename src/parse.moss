import "./inner.moss" use T;
import "./lex.moss" use Token;
import "./option.moss" use None, Option, Some;
import "./range.moss" use Range;
import "./token.moss" use *;

type TokenId;

assume TokenId {
  fn next(): TokenId;
  fn now(): TokenId;
}

fn peek(): Token;

type NameId;

context AstIds = NameId;

assume TokenId, AstIds {
  type Import = {
    from: TokenId,
    name: Option[T=TokenId],
    names: Range[T=NameId],
  };
}


type TokenSet;

assume TokenSet {
  val expected: TokenSet;

  fn TokenSet.add(kind: Token): TokenSet;

  fn err(set: TokenSet): (|);
}

context Parsing =
  TokenId, next, now, peek,
  AstIds,
  TokenSet, expected, TokenSet.add, err,
;

assume Parsing {
  fn expect(kind: Token): TokenId {
    let id = now();
    if peek() == kind {
      next();
      id
    } else {
      match err(expected.add(kind)) {}
    }
  }

  fn parse_import(): Import {
    expect(Import);
    let from = expect(Str);
    let name = match peek() {
      As => {
        next();
        Some (expect(Name))
      }
      _ => None,
    };
    var names = ();
    if peek() == Use {
      next();
      loop {
        match peek() {
          Semi => break,
          Name => names.push(next()),
          _ => (),
        }
        if peek() == Comma {
          next();
        }
      }
    }
    { from, name, names = names.done() }
  }

  fn parse_assume() {
    # TODO
  }

  fn tree() {
    loop {
      match peek() {
        Eof => return,
        Import => {
          parse_import();
        }
        Assume => {
          parse_assume();
        }
      }
    }
  }
}
