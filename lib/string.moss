import "./char.moss" use Char;
import "./int.moss" use Uint;

type String;

assume String, This {
  fn .to_string(): String;
}

type StringBuilder;

assume StringBuilder {
  assume Uint {
    fn string_builder(size: Uint): StringBuilder;

    assume Char {
      fn set_char(
        builder: StringBuilder,
        index: Uint,
        character: Char,
      ): StringBuilder;
    }
  }

  assume String {
    fn build(builder: StringBuilder): String;
  }
}
